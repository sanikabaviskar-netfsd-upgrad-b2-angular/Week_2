using System;
using System.IO;

class Program
{
    static void Main()
    {
        Console.Write("Enter root directory path: ");
        string rootPath = Console.ReadLine();

        try
        {
            // Validate directory
            if (!Directory.Exists(rootPath))
            {
                Console.WriteLine("Invalid directory path.");
                return;
            }

            DirectoryInfo rootDir = new DirectoryInfo(rootPath);

            DirectoryInfo[] subDirs = rootDir.GetDirectories();

            if (subDirs.Length == 0)
            {
                Console.WriteLine("No subdirectories found.");
                return;
            }

            Console.WriteLine("\nProject Directory Structure:\n");

            foreach (DirectoryInfo dir in subDirs)
            {
                // Count files in each subdirectory
                FileInfo[] files = dir.GetFiles();

                Console.WriteLine("Folder Name : " + dir.Name);
                Console.WriteLine("File Count  : " + files.Length);
                Console.WriteLine("-----------------------------");
            }
        }
        catch (UnauthorizedAccessException)
        {
            Console.WriteLine("Access denied. Unable to read some directories.");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error: " + ex.Message);
        }
    }
}
